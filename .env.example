# Supabase Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# Supabase Project URL
# Find this in: Supabase Dashboard → Your Project → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous/Public Key
# Find this in: Supabase Dashboard → Your Project → Settings → API → Project API keys → anon/public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Password Recovery Redirect URL (optional but recommended)
# Must also be allowed in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_TO=semesterprojectcafeteriaordering://PasswordRecovery/resetPassword

# Environment (optional)
NODE_ENV=development

# Test account for backend login script (optional, for local auth validation)
# Use a confirmed Supabase user account in your project
SUPABASE_TEST_LOGIN_EMAIL=test-user@example.com
SUPABASE_TEST_LOGIN_PASSWORD=your-test-password

# Password used for generated-account backend signup test (required for test:signup-backend)
SUPABASE_TEST_SIGNUP_PASSWORD=StrongPassword123
